# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Eliflammeem
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://central.lvh.me:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ── Sessions / Tenancy ────────────────────────────────────────────────────────
# Leave SESSION_DOMAIN empty so each tenant subdomain uses its own cookie jar.
# lvh.me automatically resolves all subdomains to 127.0.0.1 (dev).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
# pgvector required for the chatbot RAG feature. Docker compose provides it.
#   For Docker:     DB_HOST=db
#   For local dev:  DB_HOST=localhost (port forwarded from Docker)
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=eliflammeem
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Queues / Broadcast / Cache ────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────
# In dev: MAIL_MAILER=log writes emails to storage/logs/laravel.log
# In prod: MAIL_MAILER=smtp with Mailtrap or SMTP provider
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@eliflammeem.com
MAIL_FROM_NAME="${APP_NAME}"
MAIL_SUPPORT_ADDRESS=support@eliflammeem.com

# ── Storage (S3 optional) ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Document Management ───────────────────────────────────────────────────────
# Max document upload size in KB (default: 25600 = 25MB)
MAX_DOCUMENT_SIZE_KB=25600

# ── AI Services (Pro features) ────────────────────────────────────────────────
# Python microservice for issue sentiment analysis; Claude API is the fallback.
AI_SERVICE_URL=http://127.0.0.1:9000
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Cloudflare Turnstile (contact form CAPTCHA, production only) ──────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Twilio (SMS for access codes + broadcasts) ────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── Vite ──────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
